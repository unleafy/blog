---
import FormattedDate from '../FormattedDate.astro';

interface Props {
  date: Date;
  readingTime: string;
  tags: string[];
}

const { date, readingTime, tags } = Astro.props;
---

<aside class="article-info blog-card">
  <dl>
    <div>
      <dt>Reading time</dt>
      <dd>{readingTime}</dd>
    </div>
    <div>
      <dt>Created</dt>
      <dd><FormattedDate date={date} /></dd>
    </div>
  </dl>

  <div class="tags" aria-label="Article tags">
    {tags.map((tag) => <span>{tag}</span>)}
  </div>
</aside>

<style>
  .article-info {
    padding: 22px;
  }

  dl {
    display: grid;
    gap: 14px;
    margin: 0;
  }

  div {
    display: grid;
    gap: 3px;
  }

  dt {
    color: var(--paper-ink-faint);
    font-family: var(--font-ui-label);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  dd {
    margin: 0;
    color: var(--paper-ink);
    font-family: var(--font-meta);
    font-size: 0.92rem;
    font-weight: 700;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
  }

  .tags span {
    padding: 6px 10px;
    border: 1px solid var(--paper-line);
    border-radius: 8px;
    background: var(--paper-control);
    color: var(--paper-accent);
    font-family: var(--font-meta);
    font-size: 0.76rem;
    font-weight: 700;
  }
</style>
