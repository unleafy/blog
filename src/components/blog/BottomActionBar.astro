---
import { Heart, Link2, Share2, ThumbsDown } from 'lucide-astro';
---

<div class="bottom-action-bar" aria-label="Article feedback actions">
  <span>Was this helpful?</span>
  <button type="button" aria-label="Like article">
    <Heart size={17} />
  </button>
  <button type="button" aria-label="Dislike article">
    <ThumbsDown size={17} />
  </button>
  <button type="button" aria-label="Share article">
    <Share2 size={17} />
  </button>
  <button type="button" aria-label="Copy article link">
    <Link2 size={17} />
  </button>
</div>

<style>
  .bottom-action-bar {
    position: sticky;
    bottom: 24px;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: fit-content;
    max-width: 100%;
    margin: 28px auto 0;
    padding: 10px 12px 10px 18px;
    border: 1px solid var(--paper-line);
    border-radius: 8px;
    background: var(--paper-nav);
    box-shadow: var(--paper-shadow-lift);
  }

  span {
    margin-right: 4px;
    color: var(--paper-ink-soft);
    font-size: 0.86rem;
    font-weight: 700;
    white-space: nowrap;
  }

  button {
    display: inline-grid;
    place-items: center;
    width: 38px;
    height: 38px;
    padding: 0;
    border: 1px solid var(--paper-line);
    border-radius: 8px;
    background: var(--paper-control);
    color: var(--paper-ink);
    cursor: pointer;
  }

  button:hover {
    background: var(--paper-control-hover);
    color: var(--paper-accent);
  }

  @media (max-width: 520px) {
    .bottom-action-bar {
      width: 100%;
      justify-content: space-between;
      bottom: 14px;
      padding-left: 14px;
    }

    span {
      font-size: 0.8rem;
    }

    button {
      width: 34px;
      height: 34px;
      border-radius: 8px;
    }
  }
</style>
