---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../FormattedDate.astro';
import SeriesProgress from './SeriesProgress.astro';

interface Props {
  name: string;
  slug: string;
  posts: CollectionEntry<'blog'>[];
}

const { name, slug, posts } = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const href = `${basePath}/blog/series/${slug}/`;
---

<article class="series-card">
  <div class="series-heading">
    <div>
      <p>Series</p>
      <h2><a href={href}>{name}</a></h2>
    </div>
    <SeriesProgress current={posts.length} total={posts.length} />
  </div>

  <ol class="series-posts">
    {
      posts.slice(0, 4).map((post) => (
        <li>
          <a href={`${basePath}/blog/${post.id}/`}>
            <span>{post.data.title}</span>
            <small>
              <FormattedDate date={post.data.date} />
            </small>
          </a>
        </li>
      ))
    }
  </ol>

  {
    posts.length > 4 && (
      <a class="series-more" href={href}>
        View {posts.length - 4} more
      </a>
    )
  }
</article>

<style>
  .series-card {
    display: grid;
    gap: 18px;
    padding: 20px 0;
    border-top: 1px solid var(--paper-line);
  }

  .series-heading {
    display: flex;
    gap: 18px;
    align-items: start;
    justify-content: space-between;
  }

  p {
    margin: 0 0 6px;
    color: var(--paper-accent);
    font-family: var(--font-meta);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h2 {
    margin: 0;
    font-size: clamp(1.35rem, 2.6vw, 2rem);
    line-height: 1.18;
  }

  h2 a,
  .series-posts a,
  .series-more {
    color: inherit;
    text-decoration: none;
  }

  h2 a:hover,
  .series-posts a:hover span,
  .series-more:hover {
    color: var(--paper-accent);
  }

  .series-posts {
    display: grid;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
    counter-reset: series-post;
  }

  .series-posts li {
    counter-increment: series-post;
    border-top: 1px solid var(--paper-line);
  }

  .series-posts a {
    display: grid;
    grid-template-columns: 28px minmax(0, 1fr) auto;
    gap: 16px;
    align-items: baseline;
    padding: 12px 0;
    color: var(--paper-ink);
  }

  .series-posts a::before {
    color: var(--paper-ink-faint);
    font-family: var(--font-meta);
    font-size: 0.76rem;
    content: counter(series-post, decimal-leading-zero);
  }

  .series-posts span {
    grid-column: 2;
    min-width: 0;
    font-size: 1rem;
    line-height: 1.45;
  }

  .series-posts small {
    grid-column: 3;
    grid-row: 1 / span 2;
    color: var(--paper-ink-faint);
    font-family: var(--font-meta);
    font-size: 0.76rem;
  }

  .series-more {
    width: fit-content;
    color: var(--paper-ink-soft);
    font-family: var(--font-meta);
    font-size: 0.8rem;
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .series-heading {
      display: grid;
    }

    .series-posts a {
      grid-template-columns: 28px minmax(0, 1fr);
      gap: 4px;
    }

    .series-posts small {
      grid-column: 2;
      grid-row: auto;
    }
  }
</style>
