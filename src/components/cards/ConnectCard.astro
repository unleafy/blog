---
import Icon from '../Icon.astro';

interface ConnectItem {
  label: string;
  href: string;
  icon: string;
}

const { items } = Astro.props as { items: ConnectItem[] };
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');

function withBase(href: string) {
  if (href.startsWith('http') || href.startsWith('mailto:') || href.startsWith('#')) {
    return href;
  }

  if (href === '/') {
    return `${basePath}/` || '/';
  }

  return `${basePath}${href.startsWith('/') ? href : `/${href}`}`;
}
---

<article class="glass-card connect-card">
  <h2><Icon name="link" /> Connect</h2>
  <div class="connect-list">
    {
      items.map((item) => (
        <a href={withBase(item.href)} aria-label={item.label}>
          <Icon name={item.icon} />
          <span>{item.label}</span>
        </a>
      ))
    }
  </div>
</article>

<style>
  .connect-card {
    padding: 18px 24px 24px;
  }

  h2 {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0 0 14px;
    color: var(--paper-ink);
    font-size: 1.05rem;
  }

  h2 svg {
    width: 20px;
    height: 20px;
    color: var(--paper-accent);
  }

  .connect-list {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
  }

  a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 48px;
    padding: 0 12px;
    border: 1px solid var(--paper-line);
    border-radius: 8px;
    background: var(--paper-control);
    color: var(--paper-ink);
    text-decoration: none;
    box-shadow: var(--paper-shadow);
    transition:
      transform 180ms ease,
      background 180ms ease,
      color 180ms ease;
  }

  a:hover {
    background: var(--paper-control-hover);
    color: var(--paper-accent);
    transform: translateY(-1px);
  }

  svg {
    width: 20px;
    height: 20px;
    flex: 0 0 auto;
  }

  @media (max-width: 640px) {
    .connect-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
