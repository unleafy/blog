---
interface FriendLinkItem {
  name: string;
  url: string;
  bio?: string;
  avatar?: string | null;
  backgroundImage?: string | null;
}

interface Props {
  items: FriendLinkItem[];
}

const { items } = Astro.props;

const normalizedItems = items.map((item) => {
  const name = item.name.trim();
  const summary = item.bio?.trim() ?? '';
  const backgroundImageUrl = item.backgroundImage?.trim() ?? '';

  return {
    ...item,
    name,
    summary,
    backgroundImageUrl,
    hasBackgroundImage: backgroundImageUrl.length > 0,
    fallbackInitial: (name.charAt(0) || '?').toUpperCase(),
  };
});
---

<div class="friend-link-list">
  {
    normalizedItems.map((item) => (
      <a
        class:list={['friend-link-card', item.hasBackgroundImage && 'friend-link-card--with-bg']}
        href={item.url}
        target="_blank"
        rel="noopener noreferrer"
        title={item.name}
      >
        {item.hasBackgroundImage ? (
          <>
            <img
              class="friend-link-card__bg"
              src={item.backgroundImageUrl}
              alt=""
              loading="lazy"
              decoding="async"
              aria-hidden="true"
            />
            <span class="friend-link-card__bg-overlay" aria-hidden="true" />
          </>
        ) : null}
        <span class="friend-link-card__avatar" aria-hidden="true">
          {item.avatar ? (
            <img src={item.avatar} alt="" loading="lazy" decoding="async" />
          ) : (
            <span class="friend-link-card__fallback">{item.fallbackInitial}</span>
          )}
        </span>
        <span class="friend-link-card__meta">
          <strong class="friend-link-card__name">{item.name}</strong>
          {item.summary ? <span class="friend-link-card__bio">{item.summary}</span> : null}
        </span>
      </a>
    ))
  }
</div>

<style>
  .friend-link-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin: 16px 0;
  }

  .friend-link-card {
    position: relative;
    display: grid;
    grid-template-columns: 58px minmax(0, 1fr);
    align-items: center;
    gap: 12px;
    min-width: 0;
    padding: 12px;
    border: 1px solid var(--paper-line-strong);
    border-radius: 12px;
    overflow: hidden;
    isolation: isolate;
    background:
      radial-gradient(
        120% 120% at 100% 0%,
        color-mix(in srgb, var(--paper-surface) 82%, transparent) 0%,
        transparent 72%
      ),
      var(--paper-surface);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--paper-surface) 78%, transparent),
      var(--paper-shadow);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .friend-link-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--paper-line-strong) 72%, var(--paper-accent));
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--paper-surface) 85%, transparent),
      var(--paper-shadow-lift);
  }

  .friend-link-card__avatar {
    position: relative;
    z-index: 1;
    width: 58px;
    height: 58px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
    background: color-mix(in srgb, var(--paper-surface) 74%, var(--paper-ink));
    color: var(--paper-ink);
    border: 1px solid var(--paper-line-strong);
  }

  .friend-link-card__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .friend-link-card__fallback {
    font-size: 18px;
    font-weight: 700;
  }

  .friend-link-card__meta {
    position: relative;
    z-index: 1;
    min-width: 0;
    display: grid;
    gap: 4px;
  }

  .friend-link-card__name {
    font-size: 16px;
    line-height: 1.4;
  }

  .friend-link-card__bio {
    color: var(--paper-ink-soft);
    font-size: 13px;
    line-height: 1.5;
  }

  .friend-link-card__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.02);
    transition: transform 200ms ease;
    pointer-events: none;
  }

  .friend-link-card__bg-overlay {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: rgba(0, 0, 0, 0.45);
    pointer-events: none;
  }

  .friend-link-card--with-bg {
    background: var(--paper-surface);
  }

  .friend-link-card--with-bg:hover .friend-link-card__bg {
    transform: scale(1.05);
  }

  .friend-link-card--with-bg .friend-link-card__name {
    color: rgba(255, 255, 255, 0.98);
  }

  .friend-link-card--with-bg .friend-link-card__bio {
    color: rgba(255, 255, 255, 0.82);
  }

  .friend-link-card--with-bg .friend-link-card__fallback {
    color: rgba(255, 255, 255, 0.95);
  }

  @media (max-width: 720px) {
    .friend-link-list {
      grid-template-columns: 1fr;
    }
  }
</style>
