---
interface Props {
  src: string | ImageMetadata;
  alt?: string;
  height?: string;
  caption?: string;
}

const { src, alt = '', height = '420px', caption } = Astro.props;
const imageSrc = typeof src === 'string' ? src : src.src;
const viewportLabel = caption || alt || 'Scrollable image';
---

<figure class="long-image" style={`--long-image-height: ${height};`}>
  <div class="long-image__viewport" role="region" aria-label={viewportLabel} tabindex="0">
    <img src={imageSrc} alt={alt} loading="lazy" decoding="async" />
  </div>

  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .long-image {
    margin: 28px 0 30px;
  }

  .long-image__viewport {
    position: relative;
    width: 100%;
    max-height: var(--long-image-height);
    overflow-x: hidden;
    overflow-y: auto;
    border: 1px solid var(--paper-line);
    border-radius: 8px;
    background: var(--paper-surface-muted);
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--paper-surface) 72%, transparent);
    cursor: ns-resize;
    overscroll-behavior-y: contain;
    scrollbar-color: color-mix(in srgb, var(--paper-ink-faint) 42%, transparent) transparent;
    scrollbar-width: thin;
    -webkit-overflow-scrolling: touch;
  }

  .long-image__viewport::before,
  .long-image__viewport::after {
    position: sticky;
    z-index: 1;
    display: block;
    height: 24px;
    pointer-events: none;
    content: '';
  }

  .long-image__viewport::before {
    top: 0;
    margin-bottom: -24px;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--paper-surface) 86%, transparent),
      transparent
    );
  }

  .long-image__viewport::after {
    bottom: 0;
    margin-top: -24px;
    background: linear-gradient(
      0deg,
      color-mix(in srgb, var(--paper-surface) 86%, transparent),
      transparent
    );
  }

  .long-image__viewport:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--paper-accent) 36%, transparent);
    outline-offset: 3px;
  }

  .long-image__viewport::-webkit-scrollbar {
    width: 7px;
  }

  .long-image__viewport::-webkit-scrollbar-track {
    background: transparent;
  }

  .long-image__viewport::-webkit-scrollbar-thumb {
    border: 2px solid transparent;
    border-radius: 999px;
    background: color-mix(in srgb, var(--paper-ink-faint) 48%, transparent);
    background-clip: content-box;
  }

  .long-image__viewport img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0;
  }

  .long-image figcaption {
    margin-top: 9px;
    color: var(--paper-ink-faint);
    font-family: var(--font-meta);
    font-size: 0.78rem;
    line-height: 1.5;
    text-align: center;
  }

  @media (max-width: 640px) {
    .long-image {
      margin: 24px 0 26px;
    }

    .long-image__viewport {
      max-height: min(var(--long-image-height), 62vh);
      cursor: auto;
      overscroll-behavior-y: auto;
    }
  }
</style>
