---
const today = new Date();
const year = today.getFullYear();
const month = today.getMonth();
const currentDay = today.getDate();
const firstDay = (new Date(year, month, 1).getDay() + 6) % 7;
const daysInMonth = new Date(year, month + 1, 0).getDate();
const weekdays = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
const days = Array.from({ length: daysInMonth }, (_, index) => index + 1);
---

<article class="glass-card calendar-card">
  <header>
    <h2>{year}/{month + 1}</h2>
    <time datetime={today.toISOString().slice(0, 10)}>{currentDay}</time>
  </header>

  <div class="calendar-grid" aria-label={`${year}-${month + 1} calendar`}>
    {weekdays.map((day) => <span class="weekday">{day}</span>)}
    {Array.from({ length: firstDay }).map(() => <span class="day empty" aria-hidden="true" />)}
    {
      days.map((day) => (
        <time
          class:list={['day', { today: day === currentDay }]}
          datetime={`${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`}
          aria-current={day === currentDay ? 'date' : undefined}
        >
          {day}
        </time>
      ))
    }
  </div>
</article>

<style>
  .calendar-card {
    min-height: 330px;
    padding: 28px;
  }

  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  h2 {
    margin: 0;
    color: var(--paper-ink);
    font-size: 1.15rem;
  }

  header time {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border: 1px solid var(--paper-line);
    border-radius: 8px;
    background: var(--paper-control);
    color: var(--paper-accent);
    font-size: 1rem;
    font-weight: 750;
    box-shadow: var(--paper-shadow);
  }

  .calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 14px 10px;
    text-align: center;
  }

  .weekday,
  .day {
    display: grid;
    place-items: center;
    height: 31px;
    border-radius: 8px;
    color: var(--paper-ink-soft);
    font-size: 0.95rem;
  }

  .weekday {
    color: var(--paper-ink-faint);
    font-weight: 650;
  }

  .day {
    text-decoration: none;
  }

  .day.today {
    border: 1px solid var(--paper-line);
    background: var(--paper-control);
    color: var(--paper-accent);
    font-weight: 750;
    box-shadow: var(--paper-shadow);
  }

  .day.empty {
    visibility: hidden;
  }
</style>
