---
import Icon from '../Icon.astro';
---

<article class="glass-card clock-card" data-clock-widget>
  <h2><Icon name="clock" /> Local Time</h2>
  <div class="time-row">
    <time class="time-value" data-time>
      <span data-time-main>--:--</span><small data-time-seconds>:--</small>
    </time>
  </div>
  <p data-date>----</p>
</article>

<script>
  const widget = document.querySelector('[data-clock-widget]');
  const timeMainNode = widget?.querySelector('[data-time-main]');
  const secondsNode = widget?.querySelector('[data-time-seconds]');
  const dateNode = widget?.querySelector('[data-date]');
  const weekdays = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

  function updateClock() {
    const now = new Date();
    const hours = String(now.getHours()).padStart(2, '0');
    const minutes = String(now.getMinutes()).padStart(2, '0');
    const seconds = String(now.getSeconds()).padStart(2, '0');
    const date = `${now.getFullYear()}/${now.getMonth() + 1}/${now.getDate()} ${weekdays[now.getDay()]}`;

    if (timeMainNode) timeMainNode.textContent = `${hours}:${minutes}`;
    if (secondsNode) secondsNode.textContent = `:${seconds}`;
    if (dateNode) dateNode.textContent = date;
  }

  updateClock();
  window.setInterval(updateClock, 1000);
</script>

<style>
  .clock-card {
    min-height: 210px;
    padding: 30px 28px;
    overflow: hidden;
  }

  h2 {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 0 0 22px;
    color: var(--paper-ink);
    font-size: 0.95rem;
  }

  h2 svg {
    width: 22px;
    height: 22px;
    color: var(--paper-accent);
  }

  .time-row {
    display: flex;
    align-items: center;
    min-width: 0;
  }

  .time-value {
    display: flex;
    align-items: baseline;
    min-width: 0;
    color: var(--paper-ink);
    font-family: var(--font-meta);
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    font-weight: 650;
    letter-spacing: 0;
    line-height: 1;
  }

  .time-value small {
    font-size: 0.48em;
    font-weight: 650;
    line-height: 1;
  }

  p {
    margin: 12px 0 0;
    color: var(--paper-ink-soft);
    font-size: 0.86rem;
  }
</style>
