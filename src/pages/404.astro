---
import BaseLayout from '../layouts/BaseLayout.astro';

const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');

function withBase(href: string) {
  if (href === '/') {
    return `${basePath}/` || '/';
  }

  return `${basePath}${href.startsWith('/') ? href : `/${href}`}`;
}
---

<BaseLayout title="404 Not Found" description="这页暂时没有找到，可能已经迁移或还没有写下。">
  <div class="publication-bg" aria-hidden="true"></div>
  <main class="not-found-shell" aria-labelledby="not-found-title">
    <section class="not-found-panel">
      <p class="not-found-kicker">404 Not Found</p>
      <h1 id="not-found-title">这页还没有落在纸上</h1>
      <p class="not-found-copy">
        也许链接换了位置，也许这只是一次走岔的小路。先回到熟悉的入口，继续慢慢翻。
      </p>
      <nav class="not-found-actions" aria-label="404 page links">
        <a class="primary-link" href={withBase('/')}>回到首页</a>
        <a href={withBase('/blog')}>去博客</a>
      </nav>
    </section>
  </main>
</BaseLayout>

<style>
  .not-found-shell {
    display: grid;
    min-height: calc(100vh - 56px);
    place-items: center;
    padding-top: 116px;
    padding-bottom: 72px;
  }

  .not-found-panel {
    width: min(100%, 860px);
    padding: clamp(22px, 5vw, 56px) clamp(6px, 3vw, 18px);
    animation: not-found-in 420ms ease both;
  }

  .not-found-kicker {
    margin: 0 0 12px;
    color: var(--paper-accent);
    font-family: var(--font-ui-label);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  h1 {
    max-width: 11em;
    margin: 0;
    color: var(--paper-ink);
    font-size: clamp(2.3rem, 7vw, 4.6rem);
    line-height: 1.08;
  }

  .not-found-copy {
    max-width: 42rem;
    margin: 24px 0 0;
    color: var(--paper-ink-soft);
    font-size: 1.04rem;
    line-height: 1.86;
  }

  .not-found-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 30px;
  }

  .not-found-actions a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 8px 14px;
    border: 1px solid var(--paper-line);
    border-radius: 8px;
    background: var(--paper-control);
    color: var(--paper-ink);
    font-family: var(--font-ui-label);
    font-size: 0.88rem;
    font-weight: 700;
    line-height: 1.2;
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease,
      color 180ms ease;
  }

  .not-found-actions a:hover,
  .not-found-actions a:focus-visible {
    border-color: var(--paper-line-strong);
    background: var(--paper-control-hover);
    color: var(--paper-accent);
    transform: translateY(-1px);
  }

  .not-found-actions a:focus-visible {
    outline: 2px solid var(--paper-accent);
    outline-offset: 3px;
  }

  .not-found-actions .primary-link {
    border-color: color-mix(in srgb, var(--paper-accent) 24%, var(--paper-line));
  }

  @keyframes not-found-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 720px) {
    .not-found-shell {
      min-height: 100vh;
      padding-top: 92px;
      padding-bottom: 42px;
    }

    .not-found-panel {
      padding: 24px 0;
    }

    h1 {
      max-width: 8em;
      font-size: 2.34rem;
    }

    .not-found-copy {
      margin-top: 18px;
      font-size: 0.98rem;
    }

    .not-found-actions {
      display: grid;
      grid-template-columns: 1fr;
      margin-top: 24px;
    }
  }
</style>
