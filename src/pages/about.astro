---
import { getCollection, render } from 'astro:content';
import BlogArticle from '../layouts/BlogArticle.astro';

const [about] = await getCollection('about');

if (!about) {
  throw new Error('Missing src/content/about.mdx content entry.');
}

const { Content, headings } = await render(about);
---

<BlogArticle
  post={about}
  headings={headings}
  sidebar={{ enable: false, ...about.data.sidebar }}
  contentFont="ui"
>
  <Content />
</BlogArticle>
